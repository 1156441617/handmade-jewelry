# ============================================
# 手作饰品电商后端 - 环境配置
# ============================================

# 服务器配置
NODE_ENV=development
PORT=3000
API_VERSION=v1

# 数据库配置 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=handmade_jewelry
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis配置 (缓存和会话)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_too
JWT_REFRESH_EXPIRES_IN=30d

# 支付宝配置
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payments/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.com/payment/success

# 微信支付配置
WECHAT_PAY_APP_ID=your_wechat_app_id
WECHAT_PAY_MCH_ID=your_merchant_id
WECHAT_PAY_API_KEY=your_api_key
WECHAT_PAY_API_V3_KEY=your_v3_key
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/v1/payments/wechat/notify

# 邮件服务配置 (用于发送订单确认等)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@handmade-jewelry.com

# AI服务配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# 对象存储配置 (图片/视频存储)
OSS_PROVIDER=aliyun  # aliyun, qiniu, aws
OSS_ACCESS_KEY=your_access_key
OSS_SECRET_KEY=your_secret_key
OSS_BUCKET=handmade-jewelry
OSS_REGION=oss-cn-hangzhou
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# CORS配置
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log

# 限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 文件上传配置
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_PATH=uploads/

# 多平台API配置
DOUYIN_APP_KEY=
DOUYIN_APP_SECRET=
XIAOHONGSHU_APP_KEY=
XIAOHONGSHU_APP_SECRET=
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
