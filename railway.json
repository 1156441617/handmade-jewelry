{
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "setup": {
        "nodeVersion": "18"
      },
      "install": {
        "cmd": "cd handmade-jewelry-backend && npm ci"
      },
      "build": {
        "cmd": "cd handmade-jewelry-backend"
      },
      "start": {
        "cmd": "cd handmade-jewelry-backend && npm start"
      }
    }
  }
}
